# Docker Compose 项目名称
COMPOSE_PROJECT_NAME=app_backend

# 数据库配置
# 本地开发: DATABASE_HOST=localhost
# Docker 部署: DATABASE_HOST=postgres-18 (连接到外部容器)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=your_db_user
DATABASE_PASSWORD=your_db_password
DATABASE_NAME=your_db_name
INITIALIZE_DB=false

# Redis 配置
# 本地开发: REDIS_HOST=localhost
# Docker 部署: REDIS_HOST=redis (使用 docker-compose 时自动配置)
REDIS_HOST=localhost
REDIS_PORT=6379

# 应用端口配置（Docker 部署时使用）
APP_PORT=8000

# AI / 爬虫 API Key
DEEPSEEK_API_KEY=your_deepseek_api_key
DOUBAO_API_KEY=your_doubao_api_key
DOUBAO_CRAWLER_BOT_ID=your_doubao_crawler_bot_id
GPT_API_KEY=your_gpt_api_key

# Chrome Driver（可选）
# CHROME_DRIVER_PATH=/path/to/chromedriver

# JWT 认证配置
# 使用 `openssl rand -hex 32` 生成随机密钥
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
