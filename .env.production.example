# ==============================================
# 生产环境配置文件
# ==============================================
# 
# 使用说明：
# 1. 复制此文件为 .env
# 2. 填写实际的生产环境配置值
# 3. 确保此文件不会被提交到版本控制系统
#
# ==============================================

# ----------------------------------------------
# Docker 配置
# ----------------------------------------------
# 统一的 Docker Compose 项目名称
COMPOSE_PROJECT_NAME=app_backend

# ----------------------------------------------
# 数据库配置
# ----------------------------------------------
# 如果连接到外部容器，使用容器名（如 postgres-18）
# 这里的值仅作为示例，实际会被 docker-compose.yml 覆盖
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=prod_user
DATABASE_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
DATABASE_NAME=independent_backend_prod

# 首次部署设为 true 以初始化数据库，后续部署设为 false
INITIALIZE_DB=true

# ----------------------------------------------
# Redis 配置
# ----------------------------------------------
# Docker 部署时，REDIS_HOST 会自动设置为 "redis"
REDIS_HOST=redis
REDIS_PORT=6379

# ----------------------------------------------
# 应用端口配置
# ----------------------------------------------
# 应用对外暴露的端口（宿主机端口）
APP_PORT=8000

# ----------------------------------------------
# AI API 密钥配置
# ----------------------------------------------
# DeepSeek API 密钥
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# 豆包 API 密钥和配置
DOUBAO_API_KEY=your-doubao-api-key-here
DOUBAO_CRAWLER_BOT_ID=your-doubao-crawler-bot-id-here

# ----------------------------------------------
# JWT 认证配置
# ----------------------------------------------
# JWT 密钥（请使用 `openssl rand -hex 32` 生成强随机密钥）
# 示例命令：openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_THIS_TO_RANDOM_SECRET_KEY

# JWT 算法（推荐使用 HS256）
JWT_ALGORITHM=HS256

# 访问令牌过期时间（分钟）
# 生产环境建议设置较短的过期时间以提高安全性
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ----------------------------------------------
# Chrome Driver 配置（可选）
# ----------------------------------------------
# 如果需要使用爬虫功能，请配置 Chrome Driver 路径
# Docker 部署时通常不需要此配置
# CHROME_DRIVER_PATH=/usr/local/bin/chromedriver

# ==============================================
# 安全检查清单（部署前请确认）
# ==============================================
# [ ] 修改了所有 CHANGE_THIS_ 开头的配置项
# [ ] 使用了强密码（至少 16 位，包含大小写字母、数字和特殊字符）
# [ ] 使用 openssl rand -hex 32 生成了 JWT_SECRET_KEY
# [ ] DATABASE_PASSWORD 不是默认值或简单密码
# [ ] 所有 API 密钥都是生产环境的真实密钥
# [ ] 确认 .env 文件已添加到 .gitignore
# [ ] 首次部署后记得将 INITIALIZE_DB 改为 false
# ==============================================
